{
  "$schema": "https://schema.railpack.com",
  "provider": "python",
  "steps": {
    "playwright": {
      "inputs": [{ "step": "build" }],
      "commands": ["python -m playwright install --with-deps chromium"]
    }
  },
  "deploy": {
    "inputs": [{ "step": "playwright" }],
    "startCommand": "gunicorn main:app --bind 0.0.0.0:$PORT --workers 1 --timeout 120"
  }
}
